# ── Xenia backend environment ────────────────────────────────────────────────
# Copy to .env for local development. Defaults below work with docker-compose.
# Typed settings fail fast on missing required keys (app/core/config.py).
# NEVER commit real secrets. Rotation runbook: docs (Doc 08 §8).

# Runtime
ENVIRONMENT=local                       # local | staging | production
LOG_LEVEL=INFO

# Database (Railway-managed Postgres in staging/production)
DATABASE_URL=postgresql+psycopg://xenia:xenia@localhost:5432/xenia

# Supabase Auth (identity only — the backend verifies JWTs via JWKS)
SUPABASE_URL=
SUPABASE_JWT_SECRET=

# Internal console/workbench access: comma-separated Supabase auth subjects
# with Editor authorisation (Doc 08 §8). Empty = internal endpoints locked.
EDITOR_AUTH_SUBJECTS=

# Source credentials (Epic 4). Empty = family declared couldn't-see.
COMPANIES_HOUSE_API_KEY=
AD_LIBRARY_ACCESS_TOKEN=

# The honest User-Agent every research fetch carries (Doc 09 §5, N2).
POLITENESS_USER_AGENT="XeniaResearch/0.1 (+https://xenia.example/about-our-research)"

# Object storage (S3-compatible; MinIO locally, per ADR-004)
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=xenia
OBJECT_STORAGE_SECRET_KEY=xenia-local-secret
OBJECT_STORAGE_BUCKET=xenia-artefacts

# AI provider (behind the app/ai provider interface — AP6). Unused in the skeleton.
OPENAI_API_KEY=

# Billing (Epic 1 receives + queues webhooks; billing logic lands in Epic 11)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Outbound email (Resend). Without an API key, sends are logged and dropped.
RESEND_API_KEY=
EMAIL_FROM="Xenia <onboarding@resend.dev>"
# The daily worker heartbeat email recipient (the founder). Empty = skip.
HEARTBEAT_EMAIL_TO=

# Observability (per ADR-005)
SENTRY_DSN=
