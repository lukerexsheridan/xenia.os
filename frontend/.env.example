# Xenia frontend environment. Copy to .env for local development.
# The frontend holds no secrets — anon/public keys only (AP5: the desk, not the brain).
VITE_API_URL=http://localhost:8000

# Leave both blank for local dev / CI: sign-in falls back to a pasted-token
# developer screen (ADR-015). Set both against a real Supabase project to
# get the production magic-link flow.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
